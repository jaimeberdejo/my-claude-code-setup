# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local Claude state / control files (should never be committed from a working copy)
**/.claude/.last-changed
**/.claude/.phase-base
**/.claude/.phase-ready
**/.claude/.phase-grade
**/.claude/.tick-evidence.json
**/.claude/.evidence-reads
**/.claude/settings.local.json
**/AGENT_STOP
**/STEER.md
**/NEXT_FINDINGS.md
**/autopilot.log
**/test-results.json

# Secrets — never commit credentials while developing the toolkit itself.
# (Mirrors lean-stack/.gitignore; templates/examples are intentionally allowed.)
.env
.env.*
!.env.example
!.env.sample
!.env.template
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
.netrc
.git-credentials

# Language cruft (in case anyone builds the practice project in-tree)
__pycache__/
*.pyc
.venv/
node_modules/

# Local audit report (not shipped)
AUDIT.md
